#!/usr/bin/env bash
# project-flow — GitHub Project ベースの Claude 自動ワークフロー CLI
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
# シンボリックリンクを解決
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
PROJECT_FLOW_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

usage() {
  cat << 'EOF'
Usage: project-flow <command>

Commands:
  setup    カレントディレクトリ（リポルート）でセットアップ
  run      ポーラーを起動（tmux セッション）
  stop     ポーラーを停止
  status   実行中のプロジェクト一覧を表示
  logs     ログを表示

Workflow:
  Backlog → Analysis → Dev → Review → QA → Accept → Done
             (Claude)   (Claude)  (Claude)  (人間)   (自動)

Examples:
  cd ~/repos/my-project
  project-flow setup     # .project-flow.conf を作成 & GitHub Project 作成
  project-flow run       # ポーラー起動
  project-flow stop      # 停止
EOF
}

# git remote から owner/repo を取得
detect_repo() {
  local remote_url
  remote_url=$(git remote get-url origin 2>/dev/null || echo "")

  if [[ -z "$remote_url" ]]; then
    echo "ERROR: git remote 'origin' が見つかりません。git リポジトリのルートで実行してください。" >&2
    exit 1
  fi

  # SSH or HTTPS URL からパースする
  # git@github.com:owner/repo.git → owner/repo
  # https://github.com/owner/repo.git → owner/repo
  echo "$remote_url" | sed -E 's|.*github\.com[:/]||; s|\.git$||'
}

cmd_setup() {
  if [[ -f ".project-flow.conf" ]]; then
    echo ".project-flow.conf が既に存在します。"
    read -p "再セットアップしますか? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      echo "中止しました。"
      exit 0
    fi
  fi

  local repo_slug
  repo_slug=$(detect_repo)
  local owner repo_name
  owner=$(echo "$repo_slug" | cut -d'/' -f1)
  repo_name=$(echo "$repo_slug" | cut -d'/' -f2)

  echo "=== project-flow セットアップ ==="
  echo "リポジトリ: ${repo_slug}"
  echo ""

  echo "GitHub Project を作成中..."
  project_url=$(gh project create --owner "$owner" --title "${repo_name} Dev Flow" --format json | jq -r '.url')
  project_number=$(echo "$project_url" | grep -oE '[0-9]+$')

  echo "Project 作成完了: $project_url (番号: $project_number)"

  # .project-flow.conf を作成
  cat > ".project-flow.conf" << EOF
# project-flow config
# Generated by: project-flow setup
REPO="${repo_slug}"
OWNER="${owner}"
REPO_NAME="${repo_name}"
PROJECT_NUMBER="${project_number}"
STATUS_FIELD_NAME="Status"
STATUS_BACKLOG="Backlog"
STATUS_ANALYSIS="Analysis"
STATUS_DEV="Dev"
STATUS_REVIEW="Review"
STATUS_QA="QA"
STATUS_ACCEPT="Accept"
STATUS_DONE="Done"
POLL_INTERVAL="60"
LOCAL_REPO_PATH=""
EOF

  echo ""
  echo "✓ .project-flow.conf を作成しました"
  echo ""
  echo "=== 次のステップ ==="
  echo "1. Status フィールドを編集:"
  echo "   https://github.com/orgs/$owner/projects/$project_number/settings"
  echo "   (個人アカウント: https://github.com/users/$owner/projects/$project_number/settings)"
  echo ""
  echo "   必要なステータス: Backlog, Analysis, Dev, Review, QA, Accept, Done"
  echo ""
  echo "2. ポーラー起動:"
  echo "   project-flow run"
}

cmd_run() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  if [[ -z "$PROJECT_NUMBER" ]]; then
    echo "ERROR: PROJECT_NUMBER が設定されていません。先に project-flow setup を実行してください。"
    exit 1
  fi

  local session_name="$TMUX_SESSION"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    echo "既存の tmux セッション '$session_name' があります。"
    read -p "既存セッションを終了して再起動しますか? (y/N): " confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
      tmux kill-session -t "$session_name"
    else
      echo "既存セッションにアタッチします。"
      tmux attach-session -t "$session_name"
      exit 0
    fi
  fi

  echo "=== project-flow を起動します ==="
  echo "Project: ${REPO} (#${PROJECT_NUMBER})"
  echo "ポーリング間隔: ${POLL_INTERVAL}秒"
  echo ""

  # 各ウォッチャーに設定ファイルのパスを環境変数で渡す
  local conf_path="$PROJECT_CONF_FILE"
  RESTART_CMD='while true; do PROJECT_FLOW_CONF="%s" bash %s || true; echo "[$(date +%%H:%%M:%%S)] クラッシュ検出。10秒後に再起動..."; sleep 10; done'

  tmux new-session -d -s "$session_name" -n "main" \
    "$(printf "$RESTART_CMD" "$conf_path" "$PROJECT_FLOW_DIR/lib/watch-analysis.sh")"

  tmux split-window -h -t "${session_name}:main" \
    "$(printf "$RESTART_CMD" "$conf_path" "$PROJECT_FLOW_DIR/lib/watch-dev.sh")"

  tmux split-window -v -t "${session_name}:main.0" \
    "$(printf "$RESTART_CMD" "$conf_path" "$PROJECT_FLOW_DIR/lib/watch-review.sh")"

  tmux split-window -v -t "${session_name}:main.1" \
    "$(printf "$RESTART_CMD" "$conf_path" "$PROJECT_FLOW_DIR/lib/watch-accept.sh")"

  tmux set-option -t "$session_name" pane-border-status top
  tmux set-option -t "$session_name" pane-border-format " #{pane_index}: #T "

  tmux select-pane -t "${session_name}:main.0" -T "Analysis"
  tmux select-pane -t "${session_name}:main.1" -T "Dev"
  tmux select-pane -t "${session_name}:main.2" -T "Review"
  tmux select-pane -t "${session_name}:main.3" -T "Accept"

  echo "tmux セッション '$session_name' を作成しました。"
  echo "  tmux attach -t $session_name"
  echo ""

  tmux attach-session -t "$session_name"
}

cmd_stop() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  local session_name="$TMUX_SESSION"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name"
    echo "セッション '$session_name' を終了しました。"
  else
    echo "セッション '$session_name' は実行されていません。"
  fi
}

cmd_status() {
  echo "=== 実行中の project-flow セッション ==="
  tmux list-sessions 2>/dev/null | grep "^pf-" || echo "なし"
}

cmd_logs() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  tail -f "$LOG_DIR"/*.log 2>/dev/null || echo "ログファイルが見つかりません。"
}

# メインディスパッチ
command="${1:-}"

case "$command" in
  setup)   cmd_setup ;;
  run)     cmd_run ;;
  stop)    cmd_stop ;;
  status)  cmd_status ;;
  logs)    cmd_logs ;;
  -h|--help|help|"") usage ;;
  *)
    echo "ERROR: 不明なコマンド '$command'"
    usage
    exit 1
    ;;
esac
