#!/usr/bin/env bash
# project-flow — GitHub Project based Claude automation workflow CLI
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
# Resolve symlinks
while [[ -L "$SCRIPT_PATH" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
PROJECT_FLOW_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

usage() {
  cat << 'EOF'
Usage: project-flow <command>

Commands:
  setup    Setup in current directory (repo root)
  run      Start pollers (tmux session) [--debug]
  stop     Stop pollers
  attach   Attach to running tmux session
  update   Update project-flow to latest version
  status   Show running project-flow sessions
  logs     Tail log files

Workflow:
  Backlog → Analysis → Dev → Review → QA → Accept → Done
             (Claude)   (Claude)  (Claude)  (Human)  (Auto)

Examples:
  cd ~/repos/my-project
  project-flow setup     # Create .project-flow.conf & GitHub Project
  project-flow run       # Start pollers
  project-flow stop      # Stop pollers
EOF
}

# Get owner/repo from git remote
detect_repo() {
  local remote_url
  remote_url=$(git remote get-url origin 2>/dev/null || echo "")

  if [[ -z "$remote_url" ]]; then
    echo "ERROR: git remote 'origin' not found. Run this from the root of a git repository." >&2
    exit 1
  fi

  # Parse SSH or HTTPS URL
  # git@github.com:owner/repo.git → owner/repo
  # https://github.com/owner/repo.git → owner/repo
  echo "$remote_url" | sed -E 's|.*github\.com[:/]||; s|\.git$||'
}

cmd_setup() {
  if [[ -f ".project-flow.conf" ]]; then
    echo ".project-flow.conf already exists."
    read -p "Re-run setup? (y/N): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      echo "Aborted."
      exit 0
    fi
  fi

  local repo_slug
  repo_slug=$(detect_repo)
  local owner repo_name
  owner=$(echo "$repo_slug" | cut -d'/' -f1)
  repo_name=$(echo "$repo_slug" | cut -d'/' -f2)

  echo "=== project-flow setup ==="
  echo "Repository: ${repo_slug}"
  echo ""

  echo "Creating GitHub Project..."
  project_url=$(gh project create --owner "$owner" --title "${repo_name} Dev Flow" --format json | jq -r '.url')
  project_number=$(echo "$project_url" | grep -oE '[0-9]+$')

  echo "Project created: $project_url (#$project_number)"

  # Create .project-flow.conf
  cat > ".project-flow.conf" << EOF
# project-flow config
# Generated by: project-flow setup
REPO="${repo_slug}"
OWNER="${owner}"
REPO_NAME="${repo_name}"
PROJECT_NUMBER="${project_number}"
STATUS_FIELD_NAME="Status"
STATUS_BACKLOG="Backlog"
STATUS_ANALYSIS="Analysis"
STATUS_DEV="Dev"
STATUS_REVIEW="Review"
STATUS_QA="QA"
STATUS_ACCEPT="Accept"
STATUS_DONE="Done"
POLL_INTERVAL="60"
LOCAL_REPO_PATH=""
EOF

  echo ""
  echo "Created .project-flow.conf"
  echo ""
  echo "=== Next Steps ==="
  echo "1. Edit Status field:"
  echo "   https://github.com/orgs/$owner/projects/$project_number/settings"
  echo "   (Personal account: https://github.com/users/$owner/projects/$project_number/settings)"
  echo ""
  echo "   Required statuses: Backlog, Analysis, Dev, Review, QA, Accept, Done"
  echo ""
  echo "2. Start pollers:"
  echo "   project-flow run"
}

cmd_run() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  if [[ -z "$PROJECT_NUMBER" ]]; then
    echo "ERROR: PROJECT_NUMBER is not set. Run project-flow setup first."
    exit 1
  fi

  local session_name="$TMUX_SESSION"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    echo "Existing tmux session '$session_name' found."
    read -p "Kill and restart? (y/N): " confirm
    if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
      tmux kill-session -t "$session_name"
    else
      echo "Attaching to existing session."
      tmux attach-session -t "$session_name"
      exit 0
    fi
  fi

  echo "=== Starting project-flow ==="
  echo "Project: ${REPO} (#${PROJECT_NUMBER})"
  echo "Poll interval: ${POLL_INTERVAL}s"
  echo ""

  # Pass config file path and debug flag to each watcher via env var
  local conf_path="$PROJECT_CONF_FILE"
  local debug_flag="${PROJECT_FLOW_DEBUG:-0}"
  RESTART_CMD='while true; do PROJECT_FLOW_CONF="%s" PROJECT_FLOW_DEBUG="%s" bash %s || true; echo "[$(date +%%H:%%M:%%S)] Crash detected. Restarting in 10s..."; sleep 10; done'

  tmux new-session -d -s "$session_name" -n "main" \
    "$(printf "$RESTART_CMD" "$conf_path" "$debug_flag" "$PROJECT_FLOW_DIR/lib/watch-analysis.sh")"

  tmux split-window -h -t "${session_name}:main" \
    "$(printf "$RESTART_CMD" "$conf_path" "$debug_flag" "$PROJECT_FLOW_DIR/lib/watch-dev.sh")"

  tmux split-window -v -t "${session_name}:main.0" \
    "$(printf "$RESTART_CMD" "$conf_path" "$debug_flag" "$PROJECT_FLOW_DIR/lib/watch-review.sh")"

  tmux split-window -v -t "${session_name}:main.1" \
    "$(printf "$RESTART_CMD" "$conf_path" "$debug_flag" "$PROJECT_FLOW_DIR/lib/watch-accept.sh")"

  tmux set-option -t "$session_name" pane-border-status top
  tmux set-option -t "$session_name" pane-border-format " #{pane_index}: #T "

  tmux select-pane -t "${session_name}:main.0" -T "Analysis"
  tmux select-pane -t "${session_name}:main.1" -T "Dev"
  tmux select-pane -t "${session_name}:main.2" -T "Review"
  tmux select-pane -t "${session_name}:main.3" -T "Accept"

  echo "Created tmux session '$session_name'."
  echo "  tmux attach -t $session_name"
  echo ""

  tmux attach-session -t "$session_name"
}

cmd_stop() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  local session_name="$TMUX_SESSION"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name"
    echo "Session '$session_name' stopped."
  else
    echo "Session '$session_name' is not running."
  fi
}

cmd_attach() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  local session_name="$TMUX_SESSION"

  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux attach-session -t "$session_name"
  else
    echo "Session '$session_name' is not running. Run project-flow run first."
    exit 1
  fi
}

cmd_update() {
  echo "Updating project-flow..."
  local current_rev
  current_rev=$(git -C "$PROJECT_FLOW_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")

  if ! git -C "$PROJECT_FLOW_DIR" pull --ff-only 2>&1; then
    echo "ERROR: Update failed. Try manually: cd $PROJECT_FLOW_DIR && git pull"
    exit 1
  fi

  local new_rev
  new_rev=$(git -C "$PROJECT_FLOW_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown")

  if [[ "$current_rev" == "$new_rev" ]]; then
    echo "Already up to date. ($current_rev)"
  else
    echo "Updated: $current_rev -> $new_rev"
  fi
}

cmd_status() {
  echo "=== Running project-flow sessions ==="
  tmux list-sessions 2>/dev/null | grep "^pf-" || echo "None"
}

cmd_logs() {
  source "$PROJECT_FLOW_DIR/lib/config.sh"
  load_project_config

  tail -f "$LOG_DIR"/*.log 2>/dev/null || echo "No log files found."
}

# Main dispatch
command="${1:-}"
shift || true

# Parse flags
for arg in "$@"; do
  case "$arg" in
    --debug) export PROJECT_FLOW_DEBUG=1 ;;
  esac
done

case "$command" in
  setup)   cmd_setup ;;
  run)     cmd_run ;;
  stop)    cmd_stop ;;
  attach)  cmd_attach ;;
  update)  cmd_update ;;
  status)  cmd_status ;;
  logs)    cmd_logs ;;
  -h|--help|help|"") usage ;;
  *)
    echo "ERROR: Unknown command '$command'"
    usage
    exit 1
    ;;
esac
